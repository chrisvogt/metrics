{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "outputs": ["dist", "lib", "out"],
      "dependsOn": []
    },
    /**
     * `NEXT_PUBLIC_GIT_SHA` is baked into the static export in `hosting/next.config.ts`.
     * Local builds set it from `git rev-parse --short HEAD`; CI may provide `GITHUB_SHA`.
     * Without both here, Turbo can restore a cached `hosting/out` across commits and ship
     * an older UI bundle that still shows an outdated sidebar SHA.
     */
    "chronogrove-hosting#build": {
      "env": ["NEXT_PUBLIC_GIT_SHA", "GITHUB_SHA", "COMMIT_SHA", "VERCEL_GIT_COMMIT_SHA", "CF_PAGES_COMMIT_SHA"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "outputs": []
    },
    "test": {
      "outputs": []
    },
    "test:coverage": {
      "outputs": ["coverage"]
    }
  }
}
