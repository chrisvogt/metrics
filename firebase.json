{
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "functions": {
    "port": 5020,
    "predeploy": [
      "node \"$RESOURCE_DIR/../scripts/guard-functions-env.cjs\"",
      "npm --prefix \"$RESOURCE_DIR\" run build"
    ],
    "runtime": "nodejs24",
    "source": "functions",
    "codebase": "default"
  },
  "apphosting": [
    {
      "backendId": "chronogrove-console",
      "rootDir": "./hosting",
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "functions",
        ".turbo",
        "**/node_modules",
        "**/.next/cache"
      ]
    },
    {
      "backendId": "chronogrove-console-pr",
      "rootDir": "./hosting",
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "functions",
        ".turbo",
        "**/node_modules",
        "**/.next/cache"
      ]
    }
  ],
  "emulators": {
    "auth": {
      "port": 9099
    },
    "functions": {
      "port": 5001
    },
    "firestore": {
      "port": 8080
    },
    "apphosting": {
      "port": 8084,
      "host": "metrics.dev-chrisvogt.me"
    },
    "ui": {
      "enabled": true,
      "port": 4000
    }
  }
}
