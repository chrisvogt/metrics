{
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "functions": {
    "port": 5020,
    "predeploy": [
      "node \"$RESOURCE_DIR/../scripts/guard-functions-env.cjs\"",
      "npm --prefix \"$RESOURCE_DIR\" run build"
    ],
    "runtime": "nodejs24",
    "source": "functions",
    "codebase": "default"
  },
  "hosting": {
    "public": "hosting/out",
    "rewrites": [
      {
        "source": "/api/**",
        "function": "app"
      }
    ],
    "headers": [
      {
        "source": "**",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=0, must-revalidate"
          }
        ]
      },
      {
        "source": "/_next/static/**",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=31536000, immutable"
          }
        ]
      }
    ]
  },
  "emulators": {
    "auth": {
      "port": 9099
    },
    "functions": {
      "port": 5001
    },
    "firestore": {
      "port": 8080
    },
    "hosting": {
      "port": 8084,
      "host": "metrics.dev-chrisvogt.me"
    },
    "ui": {
      "enabled": true,
      "port": 4000
    }
  }
}
