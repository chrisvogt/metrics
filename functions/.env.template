# Firebase Configuration
# Copy this file to .env and fill in your actual values
# Never commit the actual .env file to version control


# Firebase Configuration (Client-Side)
# These are used by the /api/firebase-config endpoint to serve config to the client
# Set these to match your Firebase project configuration
# (If left as placeholder, public/firebase-config.js will refuse to init Firebase.)
CLIENT_API_KEY=your_api_key_here
CLIENT_AUTH_DOMAIN=your_project_id.firebaseapp.com
CLIENT_PROJECT_ID=your_project_id

# Other environment variables
NODE_ENV=development

# When true, future: resolve custom hostnames via Firestore (tenant_hosts) after env map.
# Leave unset or false until that resolver ships — default routing stays env-only.
# ENABLE_FIRESTORE_TENANT_ROUTING=false
STORAGE_FIRESTORE_DATABASE_URL=https://your_project_id.firebaseio.com
MEDIA_STORE_BACKEND=disk
LOCAL_MEDIA_ROOT=/absolute/path/to/chronogrove-local-media
MEDIA_PUBLIC_BASE_URL=/api/media/
# Optional legacy alias; MEDIA_PUBLIC_BASE_URL is preferred for new configs.
# IMAGE_CDN_BASE_URL=/api/media/

# Discogs Configuration
# Personal token + username: legacy single-tenant sync when no per-user OAuth doc exists
DISCOGS_API_KEY=your_discogs_api_key_here
DISCOGS_USERNAME=your_discogs_username_here
# OAuth 1.0a (Developer Settings → Consumer Key / Consumer Secret). Callback must match app registration.
DISCOGS_CONSUMER_KEY=
DISCOGS_CONSUMER_SECRET=
DISCOGS_OAUTH_CALLBACK_URL=https://localhost:5002/api/oauth/discogs/callback
# DISCOGS_OAUTH_SUCCESS_REDIRECT=/onboarding?oauth=discogs&status=success

# Flickr Configuration (API key = OAuth consumer key; see App Garden)
FLICKR_API_KEY=your_flickr_api_key_here
FLICKR_API_SECRET=your_flickr_app_secret_here
# Unsigned fallback for single-tenant sync when no per-user OAuth doc exists
FLICKR_USER_ID=your_flickr_user_id_here
# Must match the callback URL registered on the Flickr app (e.g. Functions hosting domain)
FLICKR_OAUTH_CALLBACK_URL=https://localhost:5002/api/oauth/flickr/callback
# Optional; relative paths use Host / PUBLIC_APP_ORIGIN
# FLICKR_OAUTH_SUCCESS_REDIRECT=/onboarding?oauth=flickr&status=success
# FLICKR_OAUTH_SUCCESS_REDIRECT=https://metrics.example/onboarding?oauth=flickr&status=success

# Local only: AES key for integration token crypto (32+ bytes, base64). Production uses the
# Secret Manager secret INTEGRATION_TOKEN_MASTER_KEY (same env name, bound in firebase-runtime-config).
# openssl rand -base64 32
INTEGRATION_TOKEN_MASTER_KEY=

# Optional: absolute origin for OAuth success/error redirects when FLICKR_OAUTH_* paths are relative
# PUBLIC_APP_ORIGIN=http://localhost:5173

# Steam Configuration
STEAM_API_KEY=your_steam_api_key_here
STEAM_USER_ID=your_steam_user_id_here

# Gemini Developer API Config (used from Firebase Functions / server-side)
# Key must NOT be restricted to "HTTP referrers" only — use "None" or "IP addresses"
# for application restrictions, or create a separate key for backend use.
GEMINI_API_KEY=your_gemini_api_key_here 

# GitHub Configuration
GITHUB_ACCESS_TOKEN=your_github_access_token_here
GITHUB_USERNAME=your_github_username_here

# Spotify Configuration
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here
SPOTIFY_REDIRECT_URI=https://localhost:8000/oauth
SPOTIFY_REFRESH_TOKEN=your_spotify_refresh_token_here

# Goodreads Configuration
GOODREADS_API_KEY=your_goodreads_api_key_here
GOODREADS_USER_ID=your_goodreads_user_id_here

# Instagram Configuration
INSTAGRAM_ACCESS_TOKEN=your_instagram_access_token_here
INSTAGRAM_USER_ID=your_instagram_user_id_here

# Google Books Configuration
GOOGLE_BOOKS_API_KEY=your_google_books_api_key_here
