{
  "name": "metrics-functions",
  "version": "0.22.8",
  "description": "Personal metrics API. A hobby project tracking my online metrics.",
  "type": "module",
  "main": "lib/index.js",
  "scripts": {
    "build": "tsc && node -e \"const fs=require('fs'); fs.cpSync('queries','lib/queries',{recursive:true}); fs.cpSync('widgets/queries','lib/widgets/queries',{recursive:true})\"",
    "deploy": "firebase deploy --only functions",
    "lint": "eslint .",
    "logs": "firebase functions:log",
    "serve": "firebase serve --only functions --port 5002",
    "shell": "firebase functions:shell",
    "start": "firebase emulators:start",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "@google-cloud/firestore": "^8.3.0",
    "@google/generative-ai": "^0.24.1",
    "axios": "^1.13.6",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.0",
    "firebase": "^12.10.0",
    "firebase-admin": "^13.7.0",
    "firebase-functions": "^7.1.0",
    "got": "^14.6.6",
    "graphql-got": "^0.1.2",
    "moment": "^2.30.1",
    "p-all": "^5.0.1",
    "p-map": "^7.0.4",
    "requestretry": "^8.0.0",
    "to-https": "^2.0.0",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^24.0.0",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitest/coverage-v8": "^4.0.18",
    "dotenv": "^17.3.1",
    "eslint": "^10.0.3",
    "firebase-functions-test": "^3.4.1",
    "globals": "^17.4.0",
    "supertest": "^7.2.2",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "private": true
}
