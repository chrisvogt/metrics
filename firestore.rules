rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    /** Slug → uid claims. Backend-only (Admin SDK bypasses these rules). */
    match /tenant_usernames/{slug} {
      allow read, write: if false;
    }

    /** OAuth + sync state per user. Backend-only until you model client-safe fields. */
    match /users/{userId}/integrations/{integrationId} {
      allow read, write: if false;
    }

    match /{document=**} {
      // Catch-all ORs with the rules above — exclude sensitive paths so reads stay denied.
      allow read: if !sensitiveFirestorePath();

      // Allow write only for service accounts in your project
      allow write: if request.auth.token.email.matches('^.*@125524759311\\.iam\\.gserviceaccount\\.com$');
    }
  }
}

/** Paths that must never be world-readable via the catch-all below. */
function sensitiveFirestorePath() {
  return request.path.matches('.*/documents/tenant_usernames(/.*)?$')
    || request.path.matches('.*/documents/users/[^/]+/integrations(/.*)?$');
}
