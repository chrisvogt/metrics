rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    /** Slug → uid claims. Admin SDK only (client SDK cannot read or write). */
    match /tenant_usernames/{slug} {
      allow read, write: if false;
    }

    /** Verified hostname → uid for custom domains. Admin SDK only. */
    match /tenant_hosts/{hostname} {
      allow read, write: if false;
    }

    /** OAuth tokens and sync secrets per user. Admin SDK only; expose safe fields via HTTPS APIs only. */
    match /users/{userId}/integrations/{integrationId} {
      allow read, write: if false;
    }

    /** Short-lived Flickr OAuth request-token lookup. Admin SDK only. */
    match /oauth_flickr_pending/{requestToken} {
      allow read, write: if false;
    }

    /**
     * All other paths (including public widget documents under users/{uid}/{provider}/**).
     * Data is served through Cloud Functions / Express (Admin SDK), not the client Firestore SDK.
     */
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
