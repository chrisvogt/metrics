# Chronogrove console (`apps/console/`) — environment template
#
# Copy to `.env.local` in this same directory. Next.js loads `.env.local` automatically
# when you run `pnpm dev` / `next dev` (restart after changes). Do not commit `.env.local`.
#
# Variables prefixed with NEXT_PUBLIC_ are inlined into the client bundle at build time
# and are visible in the browser. Never put secrets in NEXT_PUBLIC_*.

# ---------------------------------------------------------------------------
# Optional: tenant display & onboarding (have defaults in next.config.mjs)
# ---------------------------------------------------------------------------

# Public hostname for this deployment (overview hero, headers). No protocol.
# NEXT_PUBLIC_TENANT_DISPLAY_HOST=www.chrisvogt.me

# Shared public API hostname for the dashboard hero when the user has a username but no custom domain (default: api.chronogrove.com).
# NEXT_PUBLIC_DEFAULT_PUBLIC_API_HOST=api.chronogrove.com

# Hostname shown as the CNAME target in onboarding / DNS copy.
# NEXT_PUBLIC_ONBOARDING_CNAME_TARGET=personal-stats-chrisvogt.web.app

# ---------------------------------------------------------------------------
# Optional: Functions emulator (server-side fetches from `/u/[username]` in `next dev` only)
# ---------------------------------------------------------------------------

# Base URL of the `app` function on the emulator (no trailing `/api`). Defaults match next.config.mjs.
# INTERNAL_FUNCTIONS_EMULATOR_APP_ORIGIN=http://127.0.0.1:5001/personal-stats-chrisvogt/us-central1/app

# ---------------------------------------------------------------------------
# Optional: Cloud Functions origin (production-style /api proxy)
# ---------------------------------------------------------------------------

# When NODE_ENV is **not** `development`, Next rewrites `/api/*` and `/widgets/*` to this origin.
# In `next dev`, rewrites target the Functions emulator on 127.0.0.1:5001 instead (see next.config.mjs).
# Override if you use a non-default project or staging Functions URL:
# NEXT_PUBLIC_CLOUD_FUNCTIONS_APP_ORIGIN=https://us-central1-YOUR_PROJECT_ID.cloudfunctions.net/app

# Optional: override the base URL used only for **server-side** `/u/[username]` widget health fetches.
# Defaults to NEXT_PUBLIC_CLOUD_FUNCTIONS_APP_ORIGIN in production (avoids SSR calling your public tenant hostname).
# SERVER_WIDGET_FETCH_ORIGIN=https://us-central1-YOUR_PROJECT_ID.cloudfunctions.net/app

# ---------------------------------------------------------------------------
# Optional: tenant API root → public status page (`src/proxy.ts`)
# ---------------------------------------------------------------------------

# Comma-separated `hostname=usernameSlug` pairs. When the request Host matches a key,
# GET `/` is rewritten internally to `/u/{usernameSlug}` (browser URL stays `/`).
#
# Local testing: add e.g. `127.0.0.1 api.chrisvogt.local` to `/etc/hosts`, set a line below,
# then open http://api.chrisvogt.local:5173/
#
# Match the slug to a real `tenant_usernames` doc (or legacy username) in Firestore for `/u/...` data.
# NEXT_PUBLIC_TENANT_API_ROOT_TO_USERNAME=api.chrisvogt.local=chrisvogt

# Same map, server-only name (use if your hosting injects this but not the NEXT_PUBLIC_ form).
# Usually prefer NEXT_PUBLIC_TENANT_API_ROOT_TO_USERNAME for local dev.
# TENANT_API_ROOT_TO_USERNAME=api.chrisvogt.local=chrisvogt

# ---------------------------------------------------------------------------
# Optional: build metadata
# ---------------------------------------------------------------------------

# Short git SHA in the UI footer. CI often sets this; next.config.mjs also runs `git rev-parse` at build.
# NEXT_PUBLIC_GIT_SHA=localdev
